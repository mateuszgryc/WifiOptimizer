#!/bin/bash
# WiFi Optimizer - NM Dispatcher Script
# Auto-generated by WiFi Optimizer Decky plugin. Do not edit.

SETTINGS_FILE="__SETTINGS_PATH__"
SETTINGS_DIR=$(dirname "$SETTINGS_FILE")
PLUGIN_DIR="__PLUGIN_DIR__"
LOG_TAG="wifi-optimizer"

# Only fire on interface up
[ "$2" != "up" ] && exit 0

# Only fire for wifi interfaces
IFACE_TYPE=$(/usr/bin/nmcli -t -f DEVICE,TYPE dev status 2>/dev/null | grep "^${1}:" | cut -d: -f2)
[ "$IFACE_TYPE" != "wifi" ] && exit 0

IFACE="$1"

# Self-removal: if plugin directory gone, clean up
if [ ! -d "$PLUGIN_DIR" ]; then
    logger -t "$LOG_TAG" "Plugin directory gone, removing dispatcher"
    rm -f "$0"
    rm -f /etc/NetworkManager/conf.d/99-wifi-optimizer.conf
    rm -f /etc/modprobe.d/99-wifi-optimizer.conf
    exit 0
fi

# Read all settings in a single Python call for speed (<50ms)
if [ -f "$SETTINGS_FILE" ] && [ -r "$SETTINGS_FILE" ]; then
    eval $(python3 -c "
import json
try:
    d=json.load(open('$SETTINGS_FILE'))
    print(f'POWER_SAVE={\"True\" if d.get(\"power_save_disabled\",True) else \"False\"}')
    print(f'BUFFER_TUNING={\"True\" if d.get(\"buffer_tuning_enabled\",False) else \"False\"}')
except:
    print('POWER_SAVE=True')
    print('BUFFER_TUNING=False')
" 2>/dev/null)
else
    POWER_SAVE="True"
    BUFFER_TUNING="False"
    logger -t "$LOG_TAG" "Settings missing, safe defaults only"
fi

# Apply power save
if [ "$POWER_SAVE" = "True" ]; then
    /usr/bin/iw dev "$IFACE" set power_save off 2>/dev/null
    # LCD (RTL8822CE): disable deep LPS and driver ASPM (silently no-ops on OLED)
    echo Y > /sys/module/rtw88_core/parameters/disable_lps_deep 2>/dev/null
    echo Y > /sys/module/rtw88_pci/parameters/disable_aspm 2>/dev/null
    # Both: disable PCIe ASPM for WiFi device (prevents streaming throughput degradation)
    WIFI_PCI=$(readlink -f /sys/class/net/"$IFACE"/device 2>/dev/null)
    if [ -d "$WIFI_PCI/link" ]; then
        for f in l0s_aspm l1_aspm l1_1_aspm l1_2_aspm l1_1_pcipm l1_2_pcipm; do
            echo 0 > "$WIFI_PCI/link/$f" 2>/dev/null
        done
        echo on > "$WIFI_PCI/power/control" 2>/dev/null
    fi
    logger -t "$LOG_TAG" "power_save off applied to $IFACE"
fi

# Apply buffer tuning
if [ "$BUFFER_TUNING" = "True" ]; then
    /usr/bin/sysctl -w net.core.rmem_max=16777216 >/dev/null 2>&1
    /usr/bin/sysctl -w net.core.wmem_max=16777216 >/dev/null 2>&1
    /usr/bin/sysctl -w net.core.rmem_default=1048576 >/dev/null 2>&1
    /usr/bin/sysctl -w net.core.wmem_default=1048576 >/dev/null 2>&1
    /usr/bin/sysctl -w net.core.netdev_max_backlog=5000 >/dev/null 2>&1
    /usr/bin/sysctl -w net.core.netdev_budget=600 >/dev/null 2>&1
    /usr/bin/sysctl -w net.core.netdev_budget_usecs=8000 >/dev/null 2>&1
    /usr/bin/sysctl -w net.ipv4.tcp_slow_start_after_idle=0 >/dev/null 2>&1
    /usr/bin/ip link set "$IFACE" txqueuelen 2000 2>/dev/null
    logger -t "$LOG_TAG" "buffer tuning applied"
fi

# Record enforcement timestamp
date +%s > "$SETTINGS_DIR/last_enforced" 2>/dev/null

exit 0
